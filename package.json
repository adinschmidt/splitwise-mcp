{
  "name": "splitwise-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the Splitwise API",
  "type": "module",
  "bin": {
    "splitwise-mcp": "./src/index.ts"
  },
  "scripts": {
    "sync-spec": "./scripts/sync-spec.sh",
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "splitwise",
    "api",
    "bun"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.13",
    "typescript": "5.9.3"
  }
}
